FROM golang:1.25-alpine AS base

RUN apk add --no-cache git curl nodejs npm

# Go tools (versions épinglées pour cohérence local/CI)
RUN go install mvdan.cc/gofumpt@latest \
 && go install golang.org/x/tools/cmd/goimports@latest \
 && go install gotest.tools/gotestsum@latest \
 && go install go.uber.org/mock/mockgen@latest

# sqlc — binaire précompilé pour éviter la contrainte de version Go du module
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') \
 && curl -fsSL "https://github.com/sqlc-dev/sqlc/releases/download/v1.29.0/sqlc_1.29.0_linux_${ARCH}.tar.gz" \
    | tar xz -C /usr/local/bin sqlc


WORKDIR /app

COPY go.mod ./
RUN go mod download

CMD ["sh"]
