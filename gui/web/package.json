{
  "name": "@reqlet/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "tsc -b && vitest run",
    "test:watch": "vitest",
    "test:coverage": "tsc -b && vitest run --coverage",
